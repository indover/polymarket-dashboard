# Copy to `.env` and fill in your own values.
# Never commit `.env` — it's in `.gitignore`.

# ---- Required ---------------------------------------------------------------

# Your Polymarket EOA (signer) — public 40-hex address. Holds USDC.e / USDC,
# also the address used for V1 redemption signing.
POLYMARKET_ADDRESS=0xYourEoaAddressHere

# Your Polymarket V2 proxy (Magic/Safe wallet). Holds pUSD and owns V2 trades.
# To find yours: open a V2 trade tx on polygonscan, look at the address that
# receives pUSD in the ERC-20 transfer trace.
POLYMARKET_PROXY_ADDRESS=0xYourProxyAddressHere

# ---- Required for CLOB API access (trades, orders) --------------------------

CLOB_API_KEY=
CLOB_SECRET=
CLOB_PASSPHRASE=

# ---- Required only if you also run the (now-disabled) redeem path -----------

# Hex private key for the EOA above. ONLY needed if you re-enable redemption.
# Polymarket V2 auto-redeems winners, so you usually don't need this.
POLYMARKET_PRIVATE_KEY=

# ---- Optional ---------------------------------------------------------------

# Polymarket relayer credentials (only if you use the relayer flow).
RELAYER_API_KEY=
RELAYER_API_KEY_ADDRESS=

# HTTP port for the dashboard (defaults to 8080).
PORT=8080
